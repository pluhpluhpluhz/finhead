/* DATA */
function exportData(){const data={ratings,favs,achievements,playTime:totalPlayTime,theme:ST.get('theme')||'ocean',trailType,bgAnim:ST.get('bgAnim')||'none',fc:fishCount,fh:fishHue,trailHue,trailSat,trailLit};const enc=btoa(JSON.stringify(data));navigator.clipboard.writeText(enc).then(()=>alert('Copied!')).catch(()=>prompt('Copy:',enc));}
function importData(){try{const data=JSON.parse(atob(document.getElementById('import-data').value));if(data.ratings)ST.set('ratings',JSON.stringify(data.ratings));if(data.favs)ST.set('favs',JSON.stringify(data.favs));if(data.achievements)ST.set('achievements',JSON.stringify(data.achievements));if(data.playTime)ST.set('playTime',data.playTime);if(data.theme){ST.set('theme',data.theme);applyTheme(data.theme);}if(data.trailType)setTrailType(data.trailType,true);if(data.bgAnim&&data.bgAnim!=='none')setBackgroundAnim(data.bgAnim);if(data.fc){ST.set('fc',data.fc);document.getElementById('fish-count').value=data.fc;document.getElementById('fc-val').textContent=data.fc;fishCount=parseInt(data.fc);}if(data.fh){ST.set('fh',data.fh);document.getElementById('fish-hue').value=data.fh;fishHue=parseInt(data.fh);}if(data.trailHue!=null){setTrailPreset(data.trailHue,data.trailSat||100,data.trailLit||60);}alert('Imported! Reloading...');location.reload();}catch(e){alert('Invalid code!');}}
function closeDataModal(){document.getElementById('data-modal').style.display='none';}


/* THEME */
function applyTheme(theme){
  const t=THEMES[theme];if(!t)return;playSound('click');
  document.documentElement.style.setProperty('--primary',t.p);
  document.documentElement.style.setProperty('--accent',t.a);
  document.documentElement.style.setProperty('--accent-dark',t.a2);
  if(ST.get('hasBg')!=='true'){document.body.style.background=t.bg;document.body.style.backgroundSize='400% 400%';}
  document.documentElement.style.setProperty('--text-primary','#e6f1ff');
  document.documentElement.style.setProperty('--text-secondary','#8892b0');
  const isMono=theme==='mono';
  document.documentElement.style.setProperty('--text-primary',isMono?'#f0f0f0':'#e6f1ff');
  document.documentElement.style.setProperty('--text-secondary',isMono?'#999999':'#8892b0');
  document.documentElement.style.setProperty('--bg-card',isMono?'#111111':'#172a45');
  document.documentElement.style.setProperty('--bg-deep',isMono?'#000000':'#0a192f');
  document.documentElement.style.setProperty('--border',isMono?'rgba(255,255,255,0.15)':'rgba(100,255,218,0.2)');
  ST.set('theme',theme);
  document.querySelectorAll('.td').forEach(d=>d.classList.toggle('ton',d.dataset.t===theme));
}
function savePanicKey(){const k=document.getElementById('panic-key').value;if(k){playSound('click');ST.set('pk',k);alert('Panic key: '+k);}}


/* FULLSCREEN */
function toggleFullscreen(){
  if(!document.fullscreenElement){
    document.documentElement.requestFullscreen().catch(()=>{
      const w=window.open('about:blank','_blank');
      if(!w){alert('Pop-up blocked!');return;}
      const html='<!DOCTYPE html>\n'+document.documentElement.outerHTML;
      w.document.open();w.document.write(html);w.document.close();
    });
  }else{document.exitFullscreen();}
}
