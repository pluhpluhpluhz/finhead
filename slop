/* DRAGGABLE CLOCK */
let isDragging=false,cX,cY,iX,iY,xOff=0,yOff=0;
const cw=document.getElementById('clock-widget');
cw.addEventListener('mousedown',e=>{iX=e.clientX-xOff;iY=e.clientY-yOff;if(e.target===cw||e.target.parentNode===cw){isDragging=true;cw.style.cursor='grabbing';}});
document.addEventListener('mouseup',()=>{iX=cX;iY=cY;isDragging=false;cw.style.cursor='move';});
document.addEventListener('mousemove',e=>{if(!isDragging)return;e.preventDefault();cX=e.clientX-iX;cY=e.clientY-iY;xOff=cX;yOff=cY;cw.style.transform=`translate(${cX}px,${cY}px)`;});
const __hammerheadOriginalOpenLandingInAboutBlank=typeof openLandingInAboutBlank==='function'?openLandingInAboutBlank:null;
function openLandingInAboutBlank(){
  playSound('click');
  let html='';
  try{html=localStorage.getItem('hammerheadHubHTML')||'<!DOCTYPE html>'+document.documentElement.outerHTML;}catch(e){html='<!DOCTYPE html>'+document.documentElement.outerHTML;}
  html=html.replace('<body>','<body class="cloaked-window">');
  const w=window.open('about:blank','_blank');
  if(!w){showErrorToast('Allow popups to open cloak');return;}
  try{
    w.document.open();
    w.document.write(html);
    w.document.close();
    w.focus();
  }catch(e){}
  setTimeout(()=>{
    try{window.open('','_self');window.close();}catch(e){}
    setTimeout(()=>{
      if(!window.closed){
        try{location.replace('about:blank');}catch(err){document.documentElement.innerHTML='';}
      }
    },120);
  },250);
}
